PORT=3000
NODE_ENV=production
URL_SOCKET=https://api.minhoo.xyz
SHUTDOWN_GRACE_MS=15000

# Database
DB=mnh_db
USER_DB=minhoo_app
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
DB_PASSWORD_FILE=/var/www/minhoo-api/minhoo_api/.secrets/db_password
DB_HOST=127.0.0.1
DIALECT_DB=mysql
DB_SYNC_ON_BOOT=false
DB_LOG_SQL=false
DB_CONNECT_TIMEOUT_MS=10000
DB_POOL_MAX=25
DB_POOL_MIN=5
DB_POOL_ACQUIRE_MS=20000
DB_POOL_IDLE_MS=10000
DB_POOL_EVICT_MS=1000
DB_POOL_MAX_USES=7500

# Network / CORS
TRUST_PROXY=true
CORS_ALLOW_ALL_IN_PROD=false
CORS_ORIGINS=https://app.minhoo.app,https://www.minhoo.app,https://api.minhoo.xyz
HTTP_JSON_LIMIT=1mb
HTTP_URLENCODED_LIMIT=1mb
HTTP_URLENCODED_PARAMETER_LIMIT=1000
HTTP_MAX_URL_LENGTH=8192
HTTP_MAX_HEADERS_COUNT=120
HTTP_MAX_REQUESTS_PER_SOCKET=1000
HTTP_SOCKET_TIMEOUT_MS=60000
HTTP_MAX_CONNECTIONS=0
READY_CHECK_CACHE_MS=5000
READY_DB_TIMEOUT_MS=2000
APP_RATE_WINDOW_MS=60000
APP_RATE_MAX_ENTRIES=50000

# Auth abuse protection (per-IP, app-level)
AUTH_RATE_WINDOW_MS=60000
AUTH_RATE_BLOCK_MS=600000
AUTH_RATE_MAX_ENTRIES=25000
AUTH_RATE_MAX_VALIDATE_EMAIL=25
AUTH_RATE_MAX_VERIFY_EMAIL=20
AUTH_RATE_MAX_SIGNUP=8
AUTH_RATE_MAX_LOGIN=8
AUTH_RATE_MAX_REFRESH=50
AUTH_RATE_MAX_RESTORE_REQUEST=6
AUTH_RATE_MAX_RESTORE_FLOW=12
CHAT_RATE_MAX_READ=120
CHAT_RATE_MAX_WRITE=30
CHAT_RATE_MAX_REPORT=10
POST_RATE_MAX_READ=150
POST_RATE_MAX_WRITE=25
POST_RATE_MAX_SHARE_PAGE=120
REEL_RATE_MAX_READ=150
REEL_RATE_MAX_WRITE=30
REEL_RATE_MAX_SHARE_PAGE=120
INTERNAL_RATE_MAX=20

# JWT / Sessions
SECRETORPRIVATEKEY=CHANGE_ME_ACCESS_SECRET_64_PLUS_CHARS
SECRETORPRIVATEKEY_FILE=/var/www/minhoo-api/minhoo_api/.secrets/jwt_access_secret
JWT_SECRET=CHANGE_ME_ACCESS_SECRET_64_PLUS_CHARS
JWT_SECRET_FILE=/var/www/minhoo-api/minhoo_api/.secrets/jwt_access_secret
JWT_ACCESS_EXPIRES_IN=20m
JWT_EXPIRATION_GRACE_DAYS=0
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_64_PLUS_CHARS
JWT_REFRESH_SECRET_FILE=/var/www/minhoo-api/minhoo_api/.secrets/jwt_refresh_secret
JWT_REFRESH_EXPIRES_IN=45d
JWT_REFRESH_ALLOW_ACCESS_SECRET=false
AUTH_REFRESH_TOKENS_ENABLED=1
AUTH_ALLOW_ACCESS_TOKEN_REFRESH=0
AUTH_MULTI_DEVICE_SESSIONS=1
AUTH_MULTI_DEVICE_MAX_SESSIONS=40
AUTH_MULTI_DEVICE_SESSION_TTL_DAYS=60
ALLOW_SOCKET_USERID_FALLBACK=0

# Redis
SOCKET_REDIS_URL=redis://127.0.0.1:6379
REDIS_URL=redis://127.0.0.1:6379
SOCKET_MAX_HTTP_BUFFER_SIZE=1000000
SOCKET_CONNECT_TIMEOUT_MS=45000
SOCKET_PERMESSAGE_DEFLATE=0
SOCKET_RATE_LIMIT_STORE=redis
FIND_SESSION_STORE=auto
FIND_SESSION_REDIS_PREFIX=find:session

# Feed summary cache
POST_SUMMARY_CACHE_DISABLED=0
POST_SUMMARY_CACHE_TTL_SECONDS=20
REEL_SUMMARY_CACHE_DISABLED=0
REEL_SUMMARY_CACHE_TTL_SECONDS=20
HOME_SUMMARY_CACHE_DISABLED=0
HOME_SUMMARY_CACHE_TTL_SECONDS=20

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=noreply@minhoo.app
EMAIL_PASS=CHANGE_ME_EMAIL_APP_PASSWORD
EMAIL_PASS_FILE=/var/www/minhoo-api/minhoo_api/.secrets/email_pass
EMAIL_FROM="Minhoo <noreply@minhoo.app>"

# Cloudflare media
CLOUDFLARE_ACCOUNT_ID=CHANGE_ME
CLOUDFLARE_MEDIA_API_TOKEN=CHANGE_ME
CLOUDFLARE_IMAGES_API_TOKEN=CHANGE_ME
CLOUDFLARE_IMAGES_VARIANT=public
CLOUDFLARE_STREAM_ALLOWED_ORIGINS=
CLOUDFLARE_STREAM_PLAYBACK_BASE_URL=https://customer-xxxx.cloudflarestream.com

# Cloudflare R2
CLOUDFLARE_R2_ENDPOINT=https://xxxx.r2.cloudflarestorage.com
CLOUDFLARE_R2_BUCKET=static-minhoo
CLOUDFLARE_R2_ACCESS_KEY_ID=CHANGE_ME
CLOUDFLARE_R2_SECRET_ACCESS_KEY=CHANGE_ME

# Firebase Admin
FIREBASE_SERVICE_ACCOUNT_FILE=/var/www/minhoo-api/minhoo_api/.secrets/firebase-service-account.json
GOOGLE_APPLICATION_CREDENTIALS=/var/www/minhoo-api/minhoo_api/.secrets/firebase-service-account.json

# Internal / Ops
INTERNAL_DEBUG_TOKEN=CHANGE_ME
INTERNAL_DEBUG_ENABLED=1
INTERNAL_DEBUG_ALLOW_REMOTE=0
INTERNAL_DEBUG_IP_ALLOWLIST=127.0.0.1,::1
RISK_ALERT_EMAIL=info@minhoo.app
RISK_ALERT_TELEGRAM_ENABLED=0
RISK_ALERT_REMINDER_MINUTES=30
TELEGRAM_BOT_TOKEN=CHANGE_ME
TELEGRAM_CHAT_ID=CHANGE_ME
TELEGRAM_THREAD_ID=
RISK_MONITOR_STATE_FILE=/tmp/minhoo-risk-monitor-state.json
RISK_BASELINE_SAFE_RPS=55
RISK_CAPACITY_WARN_PCT=70
RISK_CAPACITY_SCALE_PCT=80
RISK_CAPACITY_CRITICAL_PCT=90
RISK_MIN_MEM_AVAILABLE_MB=700
RISK_LOAD_WARN_FACTOR=1.75
RISK_LOAD_CRITICAL_FACTOR=2.2
RISK_SCALE_ACTION_HINT="Scale now: increase VM size (4vCPU/8GB) or add a second host behind load balancer."
RISK_OBSERVABILITY_WINDOW=300
RISK_OBSERVABILITY_MIN_REQUESTS=30
RISK_OBSERVABILITY_P95_WARN_MS=900
RISK_OBSERVABILITY_P99_WARN_MS=1500
RISK_OBSERVABILITY_5XX_WARN_PCT=1.5
RISK_OBSERVABILITY_429_WARN_PCT=4
RISK_OBSERVABILITY_BOOTSTRAP_HIT_MIN_PCT=55
RISK_OBSERVABILITY_BOOTSTRAP_NOTIF_HIT_MIN_PCT=45
RISK_OBSERVABILITY_HOTSPOT_P95_WARN_MS=1800
