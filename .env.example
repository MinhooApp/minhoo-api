# Feed cache failure alerts (systemd OnFailure)
FEED_CACHE_ALERT_ENABLED=1
FEED_CACHE_ALERT_EMAIL_ENABLED=1
FEED_CACHE_ALERT_EMAIL=info@minhoo.app
FEED_CACHE_ALERT_TELEGRAM_ENABLED=1
FEED_CACHE_ALERT_TELEGRAM_CHAT_ID=
FEED_CACHE_ALERT_TELEGRAM_THREAD_ID=
FEED_CACHE_ALERT_TELEGRAM_HTTP_FAMILY=4
FEED_CACHE_ALERT_COOLDOWN_SECONDS=900
FEED_CACHE_ALERT_STATE_FILE=/tmp/minhoo-feed-cache-alert-state.json
FEED_CACHE_ALERT_SINCE_MINUTES=20
FEED_CACHE_ALERT_LINES=120

# Content create idempotency (POST /post, POST /reel)
CONTENT_CREATE_IDEMPOTENCY_TTL_SECONDS=86400
CONTENT_CREATE_IDEMPOTENCY_WAIT_MS=8000
CONTENT_CREATE_IDEMPOTENCY_WAIT_POLL_MS=250
MEDIA_MODERATION_PROVIDER_URL=https://YOUR-WORKER.workers.dev
