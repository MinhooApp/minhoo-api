CHAT_SLO_REPORT_MAX_5XX_P95_PERCENT=1
CHAT_SLO_REPORT_MAX_429_P95_PERCENT=6

# Feed SLO 24h sampling + daily report
FEED_SLO_24H_SAMPLES_FILE=/tmp/minhoo-feed-slo-samples.jsonl
FEED_SLO_24H_MAX_LINES=12000
FEED_SLO_24H_RETENTION_HOURS=72
FEED_SLO_SAMPLE_FAIL_ON_BREACH=0
FEED_SLO_REPORT_LOOKBACK_HOURS=24
FEED_SLO_REPORT_EMAIL_ENABLED=1
FEED_SLO_REPORT_EMAIL=info@minhoo.app
FEED_SLO_REPORT_TELEGRAM_ENABLED=1
FEED_SLO_REPORT_TELEGRAM_CHAT_ID=
FEED_SLO_REPORT_TELEGRAM_THREAD_ID=
