PORT=3000
NODE_ENV=production
URL_SOCKET=https://api.minhoo.xyz
SHUTDOWN_GRACE_MS=15000

# Database
DB=mnh_db
USER_DB=minhoo_app
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
DB_PASSWORD_FILE=/var/www/minhoo-api/minhoo_api/.secrets/db_password
DB_HOST=127.0.0.1
DIALECT_DB=mysql
DB_SYNC_ON_BOOT=false
DB_LOG_SQL=false
DB_CONNECT_TIMEOUT_MS=10000
DB_POOL_MAX=25
DB_POOL_MIN=5
DB_POOL_ACQUIRE_MS=20000
DB_POOL_IDLE_MS=10000
DB_POOL_EVICT_MS=1000
DB_POOL_MAX_USES=7500

# Network / CORS
TRUST_PROXY=true
CORS_ALLOW_ALL_IN_PROD=false
CORS_ORIGINS=https://app.minhoo.app,https://www.minhoo.app,https://api.minhoo.xyz
HTTP_JSON_LIMIT=1mb
HTTP_URLENCODED_LIMIT=1mb
HTTP_URLENCODED_PARAMETER_LIMIT=1000
HTTP_MAX_URL_LENGTH=8192
HTTP_MAX_HEADERS_COUNT=120
HTTP_MAX_REQUESTS_PER_SOCKET=1000
HTTP_SOCKET_TIMEOUT_MS=60000
HTTP_MAX_CONNECTIONS=0
READY_CHECK_CACHE_MS=5000
READY_DB_TIMEOUT_MS=2000
APP_RATE_WINDOW_MS=60000
APP_RATE_MAX_ENTRIES=50000

# Auth abuse protection (per-IP, app-level)
AUTH_RATE_WINDOW_MS=60000
AUTH_RATE_BLOCK_MS=600000
AUTH_RATE_MAX_ENTRIES=25000
AUTH_RATE_MAX_VALIDATE_EMAIL=25
AUTH_RATE_MAX_VERIFY_EMAIL=20
AUTH_RATE_MAX_SIGNUP=8
AUTH_RATE_MAX_LOGIN=8
AUTH_RATE_MAX_REFRESH=50
AUTH_RATE_MAX_RESTORE_REQUEST=6
AUTH_RATE_MAX_RESTORE_FLOW=12
CHAT_RATE_MAX_READ=120
CHAT_RATE_MAX_WRITE=30
CHAT_RATE_MAX_REPORT=10
POST_RATE_MAX_READ=150
POST_RATE_MAX_WRITE=25
POST_RATE_MAX_SHARE_PAGE=120
REEL_RATE_MAX_READ=150
REEL_RATE_MAX_WRITE=30
REEL_RATE_MAX_SHARE_PAGE=120
INTERNAL_RATE_MAX=20

# JWT / Sessions
SECRETORPRIVATEKEY=CHANGE_ME_ACCESS_SECRET_64_PLUS_CHARS
SECRETORPRIVATEKEY_FILE=/var/www/minhoo-api/minhoo_api/.secrets/jwt_access_secret
JWT_SECRET=CHANGE_ME_ACCESS_SECRET_64_PLUS_CHARS
JWT_SECRET_FILE=/var/www/minhoo-api/minhoo_api/.secrets/jwt_access_secret
JWT_ACCESS_EXPIRES_IN=20m
JWT_EXPIRATION_GRACE_DAYS=0
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_64_PLUS_CHARS
JWT_REFRESH_SECRET_FILE=/var/www/minhoo-api/minhoo_api/.secrets/jwt_refresh_secret
JWT_REFRESH_EXPIRES_IN=45d
JWT_REFRESH_ALLOW_ACCESS_SECRET=false
AUTH_REFRESH_TOKENS_ENABLED=1
AUTH_ALLOW_ACCESS_TOKEN_REFRESH=0
# Grace window (seconds) to accept a recently rotated refresh token.
AUTH_REFRESH_ROTATION_GRACE_SECONDS=900
AUTH_DEVICE_ROTATION_PROTECT_SECONDS=15
AUTH_OP_SINGLE_FLIGHT_WINDOW_MS=10000
AUTH_OP_DB_LOCK_TIMEOUT_SECONDS=6
AUTH_MULTI_DEVICE_SESSIONS=1
AUTH_MULTI_DEVICE_MAX_SESSIONS=40
AUTH_MULTI_DEVICE_SESSION_TTL_DAYS=60
AUTH_MULTI_DEVICE_PERSISTENT_TTL_HOURS=24
# Auth session monitor
AUTH_MONITOR_WINDOW_HOURS=24
AUTH_MONITOR_QUICK_RELOGIN_MINUTES=20
AUTH_MONITOR_MIN_AUTH_ERROR_SAMPLES=10
AUTH_MONITOR_MIN_DB_SAMPLES=20
AUTH_MONITOR_MIN_UNIQUE_LOGIN_USERS=10
AUTH_MONITOR_MAX_HARD_LOGOUT_ERROR_PCT=65
AUTH_MONITOR_MAX_REVOKED_SESSION_RATE_PCT=35
AUTH_MONITOR_MAX_QUICK_RELOGIN_USER_RATE_PCT=12
AUTH_MONITOR_STRICT=1
AUTH_MONITOR_JSON=0
AUTH_MONITOR_LOG_DIR=logs
AUTH_MONITOR_LOG_FILES=
# Auth session alert notifier
AUTH_SESSION_ALERT_ENABLED=1
AUTH_SESSION_ALERT_EMAIL_ENABLED=1
AUTH_SESSION_ALERT_EMAIL=info@minhoo.app
AUTH_SESSION_ALERT_TELEGRAM_ENABLED=1
AUTH_SESSION_ALERT_TELEGRAM_CHAT_ID=
AUTH_SESSION_ALERT_TELEGRAM_THREAD_ID=
AUTH_SESSION_ALERT_TELEGRAM_HTTP_FAMILY=4
AUTH_SESSION_ALERT_COOLDOWN_SECONDS=1800
AUTH_SESSION_ALERT_ONLY_REVOKED_RATE=1
AUTH_SESSION_ALERT_REQUIRE_IMPACT_SIGNALS=1
AUTH_SESSION_ALERT_REVOKED_CRITICAL_PCT=85
AUTH_SESSION_ALERT_REVOKED_CRITICAL_MIN_CREATED=80
AUTH_SESSION_ALERT_NOTIFY_RECOVERY=0
AUTH_SESSION_ALERT_STATE_FILE=/var/www/minhoo-api/backups/minhoo-auth-session-alert-state.json
ALLOW_SOCKET_USERID_FALLBACK=0
SOCKET_ALLOW_QUERY_TOKEN=0
AUTH_ALLOW_TOKEN_IN_QUERY_BODY=0

# Redis
SOCKET_REDIS_URL=redis://127.0.0.1:6379
REDIS_URL=redis://127.0.0.1:6379
SOCKET_MAX_HTTP_BUFFER_SIZE=1000000
SOCKET_CONNECT_TIMEOUT_MS=45000
SOCKET_PERMESSAGE_DEFLATE=0
SOCKET_RATE_LIMIT_STORE=redis
FIND_SESSION_STORE=auto
FIND_SESSION_REDIS_PREFIX=find:session

# Feed summary cache
POST_SUMMARY_CACHE_DISABLED=0
POST_SUMMARY_CACHE_TTL_SECONDS=20
POST_SUMMARY_L1_MAX_ENTRIES=2000
POST_SUMMARY_SESSION_STATE_ENABLED=0
POST_SUMMARY_VIEWER_CONTEXT_CACHE_TTL_MS=20000
POST_FEED_TOTAL_COUNT_CACHE_TTL_MS=15000
POST_PUBLIC_SUMMARY_BROWSER_MAX_AGE_SECONDS=15
POST_PUBLIC_SUMMARY_EDGE_MAX_AGE_SECONDS=75
POST_PUBLIC_SUMMARY_STALE_WHILE_REVALIDATE_SECONDS=180
POST_PUBLIC_SUMMARY_STALE_IF_ERROR_SECONDS=600
REEL_SUMMARY_CACHE_DISABLED=0
REEL_SUMMARY_CACHE_TTL_SECONDS=20
REEL_SUMMARY_L1_MAX_ENTRIES=2000
ORBIT_SUMMARY_SESSION_STATE_ENABLED=0
ORBIT_SUMMARY_VIEWER_CONTEXT_CACHE_TTL_MS=20000
ORBIT_FEED_TOTAL_COUNT_CACHE_TTL_MS=15000
REEL_SUMMARY_RELATIONSHIP_CACHE_TTL_MS=10000
REEL_PUBLIC_SUMMARY_BROWSER_MAX_AGE_SECONDS=15
REEL_PUBLIC_SUMMARY_EDGE_MAX_AGE_SECONDS=75
REEL_PUBLIC_SUMMARY_STALE_WHILE_REVALIDATE_SECONDS=180
REEL_PUBLIC_SUMMARY_STALE_IF_ERROR_SECONDS=600
HOME_SUMMARY_CACHE_DISABLED=0
HOME_SUMMARY_CACHE_TTL_SECONDS=20
HOME_PUBLIC_SUMMARY_BROWSER_MAX_AGE_SECONDS=15
HOME_PUBLIC_SUMMARY_EDGE_MAX_AGE_SECONDS=75
HOME_PUBLIC_SUMMARY_STALE_WHILE_REVALIDATE_SECONDS=180
HOME_PUBLIC_SUMMARY_STALE_IF_ERROR_SECONDS=600

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=noreply@minhoo.app
EMAIL_PASS=CHANGE_ME_EMAIL_APP_PASSWORD
EMAIL_PASS_FILE=/var/www/minhoo-api/minhoo_api/.secrets/email_pass
EMAIL_FROM="Minhoo <noreply@minhoo.app>"

# Cloudflare media
CLOUDFLARE_ACCOUNT_ID=CHANGE_ME
CLOUDFLARE_ZONE_ID=CHANGE_ME
CLOUDFLARE_ZONE_NAME=minhoo.xyz
CLOUDFLARE_CACHE_API_TOKEN=CHANGE_ME
CLOUDFLARE_MEDIA_API_TOKEN=CHANGE_ME
CLOUDFLARE_IMAGES_API_TOKEN=CHANGE_ME
CLOUDFLARE_FEED_EDGE_TTL_MODE=override_origin
CLOUDFLARE_FEED_EDGE_TTL_SECONDS=90
CLOUDFLARE_IMAGES_VARIANT=public
CLOUDFLARE_STREAM_ALLOWED_ORIGINS=
CLOUDFLARE_STREAM_PLAYBACK_BASE_URL=https://customer-xxxx.cloudflarestream.com
REEL_VALIDATE_STREAM_VARIANTS=1
REEL_ENFORCE_SAFE_STREAM_VARIANTS=0
REEL_STARTUP_SAFE_MAX_FPS=30
REEL_STREAM_PROFILE_TIMEOUT_MS=3000
REEL_STREAM_PROFILE_CACHE_TTL_MS=600000

# Cloudflare R2
CLOUDFLARE_R2_ENDPOINT=https://xxxx.r2.cloudflarestorage.com
CLOUDFLARE_R2_BUCKET=static-minhoo
CLOUDFLARE_R2_ACCESS_KEY_ID=CHANGE_ME
CLOUDFLARE_R2_SECRET_ACCESS_KEY=CHANGE_ME

# Firebase Admin
FIREBASE_SERVICE_ACCOUNT_FILE=/var/www/minhoo-api/minhoo_api/.secrets/firebase-service-account.json
GOOGLE_APPLICATION_CREDENTIALS=/var/www/minhoo-api/minhoo_api/.secrets/firebase-service-account.json

# Internal / Ops
INTERNAL_DEBUG_TOKEN=CHANGE_ME
INTERNAL_DEBUG_ENABLED=1
INTERNAL_DEBUG_ALLOW_REMOTE=0
INTERNAL_DEBUG_IP_ALLOWLIST=127.0.0.1,::1
RISK_ALERT_EMAIL=info@minhoo.app
RISK_ALERT_TELEGRAM_ENABLED=0
RISK_ALERT_REMINDER_MINUTES=30
RISK_CHECK_GREEN_ENABLED=1
TELEGRAM_BOT_TOKEN=CHANGE_ME
TELEGRAM_CHAT_ID=CHANGE_ME
TELEGRAM_THREAD_ID=
RISK_MONITOR_STATE_FILE=/tmp/minhoo-risk-monitor-state.json
RISK_BASELINE_SAFE_RPS=55
RISK_CAPACITY_WARN_PCT=70
RISK_CAPACITY_SCALE_PCT=80
RISK_CAPACITY_CRITICAL_PCT=90
RISK_MIN_MEM_AVAILABLE_MB=700
RISK_LOAD_WARN_FACTOR=1.75
RISK_LOAD_CRITICAL_FACTOR=2.2
RISK_SCALE_ACTION_HINT="Scale now: increase VM size (4vCPU/8GB) or add a second host behind load balancer."
RISK_OBSERVABILITY_WINDOW=300
RISK_OBSERVABILITY_MIN_REQUESTS=30
RISK_OBSERVABILITY_MIN_REQUESTS_GRACE_MINUTES=10
RISK_OBSERVABILITY_P95_WARN_MS=900
RISK_OBSERVABILITY_P99_WARN_MS=1500
RISK_OBSERVABILITY_5XX_WARN_PCT=1.5
RISK_OBSERVABILITY_429_WARN_PCT=4
RISK_OBSERVABILITY_BOOTSTRAP_HIT_MIN_PCT=55
RISK_OBSERVABILITY_BOOTSTRAP_NOTIF_HIT_MIN_PCT=45
RISK_OBSERVABILITY_CACHE_MIN_SAMPLES=100
RISK_OBSERVABILITY_HOTSPOT_P95_WARN_MS=1800

# Feed cache monitor (post/reel summary)
CACHE_MONITOR_BASE_URL=https://api.minhoo.xyz
CACHE_MONITOR_AUTH_TOKEN=
CACHE_MONITOR_INTERVAL_SECONDS=300
CACHE_MONITOR_CYCLES=0
CACHE_MONITOR_TIMEOUT_MS=15000
CACHE_MONITOR_JSON=0
CACHE_MONITOR_STRICT=1
CACHE_MONITOR_MIN_ANON_HIT=1
CACHE_MONITOR_MIN_AUTH_DYNAMIC=1

# Content idempotency monitor (POST /post, POST /reel)
IDEMP_MONITOR_STRICT=1
IDEMP_MONITOR_JSON=0
IDEMP_MONITOR_LOOKBACK_MINUTES=30
IDEMP_MONITOR_STUCK_MINUTES=10
IDEMP_MONITOR_MAX_STUCK=0
IDEMP_MONITOR_MIN_SAMPLES=5
IDEMP_MONITOR_MAX_CONFLICT_RATE_PCT=60
IDEMP_MONITOR_MAX_SERVER_ERROR_RATE_PCT=10
IDEMP_MONITOR_REQUIRE_RECENT_ACTIVITY=0

# Feed SLO monitor (Day 1)
FEED_SLO_BASE_URL=http://127.0.0.1:3000
FEED_SLO_WINDOW=300
FEED_SLO_TIMEOUT_MS=15000
FEED_SLO_STRICT=1
FEED_SLO_JSON=0
FEED_SLO_MIN_WINDOW_REQUESTS=40
FEED_SLO_MIN_ROUTE_SAMPLES=20
FEED_SLO_POST_SUMMARY_P95_MS=250
FEED_SLO_REEL_SUMMARY_P95_MS=220
FEED_SLO_BOOTSTRAP_FULL_P95_MS=1200
FEED_SLO_MAX_5XX_PERCENT=0.5
FEED_SLO_MAX_429_PERCENT=4
FEED_SLO_STRICT_429=0
FEED_SLO_CACHE_MIN_SAMPLES=100
FEED_SLO_BOOTSTRAP_HIT_MIN_PERCENT=55
FEED_SLO_BOOTSTRAP_NOTIF_HIT_MIN_PERCENT=45

# Chat SLO monitor (Day 1)
CHAT_SLO_BASE_URL=http://127.0.0.1:3000
CHAT_SLO_WINDOW=300
CHAT_SLO_TIMEOUT_MS=15000
CHAT_SLO_STRICT=1
CHAT_SLO_JSON=0
CHAT_SLO_INTERNAL_DEBUG=1
CHAT_SLO_INTERNAL_DEBUG_TOKEN=
CHAT_SLO_MIN_WINDOW_REQUESTS=40
CHAT_SLO_MIN_ROUTE_SAMPLES=15
CHAT_SLO_CHAT_SUMMARY_P95_MS=220
CHAT_SLO_CHAT_MESSAGE_SUMMARY_P95_MS=130
CHAT_SLO_CHAT_SEND_P95_MS=350
CHAT_SLO_CHAT_FULL_P95_MS=600
CHAT_SLO_MAX_5XX_PERCENT=1
CHAT_SLO_MAX_429_PERCENT=5
CHAT_SLO_MAX_4XX_PERCENT=35
CHAT_SLO_STRICT_429=0
CHAT_SLO_STRICT_4XX=0
CHAT_SLO_REQUIRE_TRAFFIC=0

# Chat SLO 24h report (burn-in)
CHAT_SLO_REPORT_LOOKBACK_HOURS=24
CHAT_SLO_REPORT_SERVICE=minhoo-chat-slo-monitor.service
CHAT_SLO_REPORT_STRICT=1
CHAT_SLO_REPORT_JSON=0
CHAT_SLO_REPORT_MIN_RUNS=200
CHAT_SLO_REPORT_MAX_FAIL_RUNS=0
CHAT_SLO_REPORT_MAX_WARNING_RUNS=20
