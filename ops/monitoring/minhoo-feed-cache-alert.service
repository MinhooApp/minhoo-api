[Unit]
Description=Minhoo Feed Cache Monitor Failure Alert
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=appuser
Group=appuser
WorkingDirectory=/var/www/minhoo-api/minhoo_api
Environment=NODE_ENV=production
ExecStart=/usr/bin/node /var/www/minhoo-api/minhoo_api/scripts/notify-feed-cache-alert.js --unit minhoo-feed-cache-monitor.service
